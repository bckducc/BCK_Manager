{
  "info": {
    "_postman_id": "bck-manager-api-v1",
    "name": "BCK Manager API v1",
    "description": "BCK Manager Backend API Collection for testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"token\", jsonData.data.token);",
                  "    pm.environment.set(\"userId\", jsonData.data.user.id);",
                  "    pm.environment.set(\"userRole\", jsonData.data.user.role);",
                  "    console.log(\"Token saved: \" + jsonData.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"landlord1\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login with username and password"
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Get current authenticated user information"
          },
          "response": []
        },
        {
          "name": "Check User - Test (landlord1)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/check-user?username=landlord1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "check-user"],
              "query": [
                {
                  "key": "username",
                  "value": "landlord1"
                }
              ]
            },
            "description": "Check if user exists (using test user landlord1)"
          },
          "response": []
        },
        {
          "name": "Check User - Test (tenant1)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/check-user?username=tenant1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "check-user"],
              "query": [
                {
                  "key": "username",
                  "value": "tenant1"
                }
              ]
            },
            "description": "Check if user exists (using test user tenant1)"
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Logout user (client removes token)"
          },
          "response": []
        }
      ]
    },
